from datetime import datetime

print("===== PYTHON VOICE ASSISTANT =====")

while True:

    command = input("\nYou: ").lower()

    if command == "hello":
        print("Assistant: Hello! How can I help you?")

    elif command == "time":
        current_time = datetime.now().strftime("%H:%M:%S")
        print("Assistant: Current time is", current_time)

    elif command == "date":
        current_date = datetime.now().strftime("%d-%m-%Y")
        print("Assistant: Today's date is", current_date)

    elif command == "how are you":
        print("Assistant: I am fine. Thank you!")

    elif command == "bye":
        print("Assistant: Goodbye!")
        break

    else:
        print("Assistant: Sorry, I don't understand that command.")
        
        
